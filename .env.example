# ───────────────────────────────────────────────────────────────────────────
# CocktailBot — Environment Variables
# Copy this file to .env and fill in your values.
# ───────────────────────────────────────────────────────────────────────────

# ── Telegram Bot ─────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ── PostgreSQL ───────────────────────────────────────────────────────────
POSTGRES_DB=cocktaildb
POSTGRES_USER=cocktail
POSTGRES_PASSWORD=cocktail

# DATABASE_URL is constructed automatically in docker-compose.
# Only set manually for local runs without Docker:
# DATABASE_URL=postgresql+asyncpg://cocktail:cocktail@localhost:5432/cocktaildb

# ── Backend ──────────────────────────────────────────────────────────────
# Used by the bot to reach the backend.
# In Docker: http://backend:8000 (set automatically by docker-compose)
# For local non-Docker run: http://localhost:8000
BACKEND_URL=http://localhost:8000

# ── External Cocktail API ────────────────────────────────────────────────
# TheCocktailDB free API — no key needed
COCKTAILDB_BASE_URL=https://www.thecocktaildb.com/api/json/v1/1

# ── Optional LLM Integration ─────────────────────────────────────────────
# Set LLM_ENABLED=true to enable natural language understanding.
# If false or credentials are missing, bot uses deterministic intent detection.
# Set LLM_ENABLED=true and provide an OpenRouter API key to enable natural language understanding.
# Recommended free model: z-ai/glm-4.5-air:free (no credits consumed on OpenRouter)
# Get your API key at: https://openrouter.ai/keys
LLM_ENABLED=false
LLM_API_KEY=
LLM_API_BASE_URL=https://openrouter.ai/api/v1
LLM_API_MODEL=z-ai/glm-4.5-air:free

# ── App Settings ─────────────────────────────────────────────────────────
DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# ── pgAdmin (Database Management) ────────────────────────────────────────
# Web interface for PostgreSQL - accessible at http://localhost:5050
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=admin
